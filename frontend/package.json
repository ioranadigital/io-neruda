{
  "name": "neruda-frontend",
  "version": "1.0.0",
  "description": "Dashboard io-neruda para gestión de contenidos",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev -p 3003",
    "build": "next build",
    "start": "next start -p ${PORT:-3003}",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "lucide-react": "^0.365.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.8",
    "@types/node": "20.17.6",
    "@types/react": "18.3.29",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next": "^15.1.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  }
}
